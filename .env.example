# SendMyMail frontend — environment template
# Copy this to .env.local and fill in your local values. NEVER commit .env.local.

# Backend API base URL. The frontend's fetch wrapper prepends this to every call.
# Local dev: backend runs on :4000 by default.
# Prod: https://api.sendmymail.io
VITE_BACKEND_URL=http://localhost:4000

# Cloudinary direct-upload (browser → Cloudinary, no backend involvement).
# Create a free account at cloudinary.com (no credit card required) and an
# UNSIGNED upload preset (Settings → Upload → Add upload preset → Signing
# Mode = Unsigned). Both values below are safe to expose in client code
# — the preset config (allowed types / size limit / target folder) is
# what prevents abuse, not the secrecy of the preset name.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
